{
  "name": "gaeldle",
  "author": "Gaël Jacquin",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint --filter '!@workspace/ui'",
    "lint:fix": "turbo lint --filter '!@workspace/ui' -- --fix",
    "lint:web": "turbo lint --filter @workspace/web",
    "test": "turbo test",
    "test:web": "turbo test --filter @workspace/web",
    "format": "prettier --check .",
    "format:write": "prettier --write . --ignore-unknown",
    "typecheck": "turbo typecheck",
    "add:web": "pnpm --filter ./apps/web add",
    "add:ui": "pnpm --filter ./packages/ui add",
    "sync": "./remote-sync.sh",
    "sync:list": "mutagen sync list",
    "sync:list-long": "mutagen sync list --long",
    "sync:monitor": "mutagen sync monitor gaeldle",
    "sync:pause": "mutagen sync pause gaeldle",
    "sync:resume": "mutagen sync resume gaeldle",
    "sync:terminate": "mutagen sync terminate gaeldle",
    "sync:reset": "mutagen sync reset gaeldle",
    "prepare": "husky"
  },
  "keywords": [],
  "packageManager": "pnpm@11.5.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16"
  },
  "dependencies": {
    "motion": "^12.40.0",
    "zod": "^4.4.3"
  }
}
