{
  "name": "gaeldle",
  "author": "Gaël Jacquin",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=!@workspace/newapi",
    "dev": "turbo run dev --filter=!@workspace/newapi",
    "lint": "turbo lint --filter '!@workspace/ui'",
    "lint:fix": "turbo lint --filter '!@workspace/ui' -- --fix",
    "lint:web": "turbo lint --filter @workspace/web",
    "db:generate": "pnpm --filter ./apps/api db:generate",
    "db:migrate": "pnpm --filter ./apps/api db:migrate",
    "db:push": "pnpm --filter ./apps/api db:push",
    "db:studio": "pnpm --filter ./apps/api db:studio",
    "db:refresh-all-mat-views": "pnpm --filter ./apps/api db:refresh-all-mat-views",
    "test": "turbo test",
    "test:web": "turbo test --filter @workspace/web",
    "format": "prettier --check .",
    "format:write": "prettier --write . --ignore-unknown",
    "typecheck": "turbo typecheck",
    "add:web": "pnpm --filter ./apps/web add",
    "add:ui": "pnpm --filter ./packages/ui add",
    "sync": "./start-remote-sync.sh",
    "sync:list": "mutagen sync list",
    "sync:list-long": "mutagen sync list --long",
    "sync:monitor": "mutagen sync monitor gaeldle",
    "sync:pause": "mutagen sync pause gaeldle",
    "sync:resume": "mutagen sync resume gaeldle",
    "sync:terminate": "./stop-remote-sync.sh",
    "sync:reset": "mutagen sync reset gaeldle",
    "prepare": "husky"
  },
  "keywords": [],
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^25.9.5",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
